{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-internal"],
  "ignoreDependencies": ["tailwindcss", "pngjs", "@types/pngjs"],
  "ignore": [
    "webview-ui/src/office/components/index.ts",
    "webview-ui/src/office/editor/index.ts",
    "webview-ui/src/office/engine/index.ts",
    "webview-ui/src/office/layout/index.ts",
    "webview-ui/src/office/sprites/index.ts"
  ],
  "workspaces": {
    ".": {
      "entry": ["shared/assets/loader.ts"],
      "project": ["shared/**/*.ts"]
    },
    "app": {
      "entry": ["src/index.ts", "scripts/*.mjs"],
      "project": ["src/**/*.ts", "scripts/**/*.mjs"]
    },
    "webview-ui": {
      "entry": ["src/main.tsx", "test/**/*.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
