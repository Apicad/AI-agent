# Pixel Agents Environment Variables
# Copy this file to .env and uncomment variables as needed.
# .env is gitignored and loaded automatically by the F5 launch config.

# Enable verbose debug logging for hook events (SessionStart, SessionEnd, Stop, etc.)
PIXEL_AGENTS_DEBUG=1

# PixelLab API key for furniture generation scripts (scripts/generate/furniture.ts)
# Get your key at: https://pixellab.ai
PIXELLAB_API_KEY=your-key-here

# Standalone mode only: comma-separated absolute paths that spawned agents may
# access (injected via Claude Code's --add-dir at spawn). Defaults to /tmp.
# PIXEL_AGENTS_WORKSPACE_DIRS=/path/to/project-a,/path/to/project-b
